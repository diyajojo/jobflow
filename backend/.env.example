# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/job_autofiller  # Note: port 5433 to avoid conflict with local postgres instance
REDIS_URL=redis://localhost:6379/0

# Groq API Configuration (for LLM-based scoring and reasoning)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
SCORING_MODEL=llama-3.1-8b-instant

# Apify Configuration (for LinkedIn job scraping)
APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=curious_coder/linkedin-jobs-scraper

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# Database Credentials (for Docker)
DB_USER=postgres
DB_PASSWORD=postgres
